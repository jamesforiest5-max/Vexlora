local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedInstantReload = false
getgenv().CertifiedOriginalReloadTimes = getgenv().CertifiedOriginalReloadTimes or {}
getgenv().CertifiedReloadConnections = getgenv().CertifiedReloadConnections or {}

local function HandleReloadTool(tool)
	if not tool or not tool:IsA("Tool") then return end

	local settingModule = tool:FindFirstChild("Setting")
	if not settingModule then return end

	local success, setting = pcall(require, settingModule)
	if not success or type(setting) ~= "table" then return end

	if getgenv().CertifiedOriginalReloadTimes[tool] == nil then
		getgenv().CertifiedOriginalReloadTimes[tool] = setting.ReloadTime or 0
	end

	if getgenv().CertifiedInstantReload then
		setting.ReloadTime = 0
		setting.ReloadAnimationSpeed = 999
	else
		setting.ReloadTime = getgenv().CertifiedOriginalReloadTimes[tool] or 0
	end
end

local function ApplyInstantReload()
	local char = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")

	if backpack then
		for _, tool in ipairs(backpack:GetChildren()) do
			HandleReloadTool(tool)
		end
	end

	if char then
		for _, tool in ipairs(char:GetChildren()) do
			HandleReloadTool(tool)
		end
	end
end

local function WatchContainer(container)
	if not container then return end
	if getgenv().CertifiedReloadConnections[container] then return end

	getgenv().CertifiedReloadConnections[container] = container.ChildAdded:Connect(function(child)
		task.wait(0.1)
		HandleReloadTool(child)
	end)
end

local function SetupInstantReloadWatchers()
	WatchContainer(LocalPlayer:FindFirstChild("Backpack"))

	if LocalPlayer.Character then
		WatchContainer(LocalPlayer.Character)
	end
end

LocalPlayer.CharacterAdded:Connect(function(char)
	task.wait(1)
	WatchContainer(char)
	ApplyInstantReload()
end)

task.spawn(function()
	while task.wait(0.5) do
		if getgenv().CertifiedInstantReload then
			SetupInstantReloadWatchers()
			ApplyInstantReload()
		end
	end
end)

