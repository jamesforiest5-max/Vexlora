getgenv().VexOpenButton = nil
getgenv().VexDragging = false
getgenv().VexDragStart = nil
getgenv().VexStartPos = nil
getgenv().VexDragInput = nil

getgenv().FindVexOpenButton = function()
    for _, v in ipairs(getgenv().CoreGui:GetDescendants()) do
        if v:IsA("GuiObject") then
            if v.Name:lower():find("open")
            or v.Name:lower():find("button")
            or v.Name:lower():find("wind") then
                if v.AbsoluteSize.X >= 80 and v.AbsoluteSize.Y >= 35 then
                    return v
                end
            end
        end
    end

    for _, v in ipairs(getgenv().LocalPlayer.PlayerGui:GetDescendants()) do
        if v:IsA("GuiObject") then
            if v.Name:lower():find("open")
            or v.Name:lower():find("button")
            or v.Name:lower():find("wind") then
                if v.AbsoluteSize.X >= 80 and v.AbsoluteSize.Y >= 35 then
                    return v
                end
            end
        end
    end

    return nil
end

task.spawn(function()
    repeat
        task.wait(0.25)
        getgenv().VexOpenButton = getgenv().FindVexOpenButton()
    until getgenv().VexOpenButton

    getgenv().VexOpenButton.Position = UDim2.new(0.5, -75, 0, 65)
    getgenv().VexOpenButton.Active = true

    getgenv().VexOpenButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            getgenv().VexDragging = true
            getgenv().VexDragStart = input.Position
            getgenv().VexStartPos = getgenv().VexOpenButton.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    getgenv().VexDragging = false
                end
            end)
        end
    end)

    getgenv().VexOpenButton.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            getgenv().VexDragInput = input
        end
    end)

    getgenv().UIS.InputChanged:Connect(function(input)
        if input == getgenv().VexDragInput and getgenv().VexDragging then
            getgenv().VexDelta = input.Position - getgenv().VexDragStart

            getgenv().VexOpenButton.Position = UDim2.new(
                getgenv().VexStartPos.X.Scale,
                getgenv().VexStartPos.X.Offset + getgenv().VexDelta.X,
                getgenv().VexStartPos.Y.Scale,
                getgenv().VexStartPos.Y.Offset + getgenv().VexDelta.Y
            )
        end
    end)
end)



