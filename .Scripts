local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedAutoGun = false
getgenv().CertifiedNoFireRate = false

local function GetGun()
	local Character = LocalPlayer.Character
	if not Character then return nil end

	return Character:FindFirstChildOfClass("Tool")
end

local function ApplyGunMods()
	local Tool = GetGun()
	if not Tool then return end

	local SettingModule = Tool:FindFirstChild("Setting")
	if not SettingModule then return end

	pcall(function()
		local Setting = require(SettingModule)

		-- Automatic Gun
		if getgenv().CertifiedAutoGun then
			if Setting.Auto ~= nil then
				Setting.Auto = true
			end

			if Setting.Automatic ~= nil then
				Setting.Automatic = true
			end

			if Setting.AutoFire ~= nil then
				Setting.AutoFire = true
			end

			if Setting.FireMode ~= nil then
				Setting.FireMode = "Auto"
			end

			if Setting.Mode ~= nil then
				Setting.Mode = "Auto"
			end
		end

		-- No Fire Rate
		if getgenv().CertifiedNoFireRate then
			if Setting.FireRate ~= nil then
				Setting.FireRate = 0
			end

			if Setting.Cooldown ~= nil then
				Setting.Cooldown = 0
			end

			if Setting.Delay ~= nil then
				Setting.Delay = 0
			end

			if Setting.ShotCooldown ~= nil then
				Setting.ShotCooldown = 0
			end

			if Setting.FireCooldown ~= nil then
				Setting.FireCooldown = 0
			end
		end
	end)
end

task.spawn(function()
	while task.wait(0.15) do
		if getgenv().CertifiedAutoGun or getgenv().CertifiedNoFireRate then
			ApplyGunMods()
		end
	end
end)

TargetTab:Toggle({
	Title = "Fully Auto",
	Value = false,

	Callback = function(Value)
		getgenv().CertifiedAutoGun = Value

		if Value then
			ApplyGunMods()
		end
	end
})

TargetTab:Toggle({
	Title = "Super Auto",
	Value = false,

	Callback = function(Value)
		getgenv().CertifiedNoFireRate = Value

		if Value then
			ApplyGunMods()
		end
	end
})

