local function updateCharacterReferences()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local root = character:WaitForChild("HumanoidRootPart", 10)
	local humanoid = character:FindFirstChildOfClass("Humanoid")

	humanoidRootPart = root

	return character, root, humanoid
end

local function Teleport(cframe)
	local character, root, humanoid = updateCharacterReferences()

	if not character or not root or not humanoid or not cframe then
		return
	end

	getgenv().SwimMethod = true

	pcall(function()
		humanoid:ChangeState(0)
	end)

	local timeout = tick() + 1

	repeat
		task.wait()
	until not LocalPlayer:GetAttribute("LastACPos") or tick() > timeout

	root.CFrame = cframe

	task.wait(0.1)

	pcall(function()
		humanoid:ChangeState(1)
	end)

	getgenv().SwimMethod = false
end

MainTab:Dropdown({
	Title = "Teleports",
	Values = locationNames,
	Value = locationNames[1],

	Callback = function(option)
		local selectedName = typeof(option) == "table" and option[1] or option

		for _, location in ipairs(teleportLocations) do
			if location.Title == selectedName then
				selectedTeleport = location
				break
			end
		end
	end
})

MainTab:Button({
	Title = "Teleport To Location",

	Callback = function()
		if selectedTeleport then
			Teleport(CFrame.new(selectedTeleport.Position))
		end
	end
})



