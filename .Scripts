local function GiveEquippedGunAmmo()
	local char = LocalPlayer.Character
	if not char then return end

	local gun = char:FindFirstChildOfClass("Tool")
	if not gun then return end

	local settingModule = gun:FindFirstChild("Setting")
	if not settingModule then return end

	pcall(function()
		local setting = require(settingModule)

		setting.LimitedAmmoEnabled = false
		setting.MaxAmmo = 100000
		setting.AmmoPerMag = 100000
		setting.Ammo = 100000
		setting.CurrentAmmo = 100000
		setting.MagAmmo = 100000
		setting.AmmoInMag = 100000
		setting.AmmoInClip = 100000
		setting.StoredAmmo = 100000
		setting.ReserveAmmo = 100000
		setting.ClipSize = 100000
	end)
end

