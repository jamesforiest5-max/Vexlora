getgenv().P.SetCameraBack = function()
	getgenv().P.MyChar = getgenv().P.LocalPlayer.Character
	if not getgenv().P.MyChar then return end

	getgenv().P.MyHumanoid = getgenv().P.MyChar:FindFirstChildWhichIsA("Humanoid")
