	Callback = function(Value)
		getgenv().SaturationEnabled = Value

		if Value then
			getgenv().ColorCorrection.Saturation = getgenv().SaturationLevel / 100
		else
			getgenv().ColorCorrection.Saturation = 0
		end
	end
})

LockerTab:Slider({
	Title = "Saturation Level",
	Value = {
		Min = 0,
		Max = 200,
		Default = 100,
	},
	Step = 1,
	Callback = function(Value)
		getgenv().SaturationLevel = Value

		if getgenv().SaturationEnabled then
			getgenv().ColorCorrection.Saturation = Value / 100
		end
	end
})

LockerTab:Divider()

getgenv().Lighting = game:GetService("Lighting")
getgenv().RunService = game:GetService("RunService")

getgenv().DefaultLighting = getgenv().DefaultLighting or {
	Brightness = getgenv().Lighting.Brightness,
	GlobalShadows = getgenv().Lighting.GlobalShadows,
	OutdoorAmbient = getgenv().Lighting.OutdoorAmbient,
	ExposureCompensation = getgenv().Lighting.ExposureCompensation,
	ClockTime = getgenv().Lighting.ClockTime
}

getgenv().WorldTimeEnabled = false
getgenv().WorldTimeValue = 12


LockerTab:Toggle({
	Title = "Enable Time Changer",
	Value = false,
	Callback = function(Value)
		getgenv().WorldTimeEnabled = Value

		if not Value then
			getgenv().Lighting.ClockTime = getgenv().DefaultLighting.ClockTime
		end
	end
})

LockerTab:Slider({
	Title = "Time (0-24)",
	Value = {
		Min = 0,
		Max = 24,
		Default = 12
	},
	Step = 0.1,
	Callback = function(Value)
		getgenv().WorldTimeValue = Value
	end
})

if getgenv().LightingLoop then
	getgenv().LightingLoop:Disconnect()
end

getgenv().LightingLoop = getgenv().RunService.RenderStepped:Connect(function()
	if getgenv().FullBrightEnabled then
		getgenv().Lighting.Brightness = 5
		getgenv().Lighting.GlobalShadows = false
		getgenv().Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
		getgenv().Lighting.ExposureCompensation = 0
	end

	if getgenv().WorldTimeEnabled then
		getgenv().Lighting.ClockTime = getgenv().WorldTimeValue
	end
end)

------------------------------------------------
-- CLEAN DIVIDER LIKE IMAGE
------------------------------------------------

Window:Divider()

------------------------------------------------
-- SETTINGS SECTION
------------------------------------------------

getgenv().SettingsSection = Window:Section({
    Title = "Other",
    Icon = "settings",
    Opened = true,
})

getgenv().SettingsTab = getgenv().SettingsSection:Tab({
    Title = "Settings",
    Icon = "settings"
})

getgenv().UpdateLogsTab = getgenv().SettingsSection:Tab({
    Title = "Update Logs",
    Icon = "bell"
})

------------------------------------------------
-- SETTINGS FUNCTIONS
------------------------------------------------



------------------------------------------------
-- SETTINGS UI
------------------------------------------------


getgenv().SelectedWindTheme = "Dark"
getgenv().ThemeChangerEnabled = false

getgenv().ThemeList = {
	"Dark",
	"Light",
	"Rose",
	"Plant",
	"Red",
	"Indigo",
	"Sky",
	"Violet",
	"Amber",
	"Emerald"
}

getgenv().SettingsTab:Section({
	Title = "UI Settings"
})

getgenv().SettingsTab:Dropdown({
	Title = "Select Theme",
	Values = getgenv().ThemeList,
	Value = getgenv().SelectedWindTheme,
	Callback = function(Option)
		getgenv().SelectedWindTheme = typeof(Option) == "table" and Option[1] or Option

		if getgenv().ThemeChangerEnabled then
			WindUI:SetTheme(getgenv().SelectedWindTheme)
		end
	end
})

getgenv().SettingsTab:Toggle({
	Title = "Enable Theme",
	Value = false,
	Callback = function(Value)
		getgenv().ThemeChangerEnabled = Value

		if Value then
			WindUI:SetTheme(getgenv().SelectedWindTheme)
		else
			WindUI:SetTheme("Dark")
		end
	end
})

SettingsTab:Divider()

