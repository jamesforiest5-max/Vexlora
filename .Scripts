local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedReduceRecoil = false
getgenv().CertifiedOriginalRecoil = getgenv().CertifiedOriginalRecoil or {}
getgenv().CertifiedRecoilConnections = getgenv().CertifiedRecoilConnections or {}

local function HandleRecoilTool(tool)
	if not tool or not tool:IsA("Tool") then return end

	local settingModule = tool:FindFirstChild("Settings") or tool:FindFirstChild("Setting")
	if not settingModule then return end

	local success, settings = pcall(require, settingModule)
	if not success or type(settings) ~= "table" then return end

	if getgenv().CertifiedOriginalRecoil[tool] == nil then
		getgenv().CertifiedOriginalRecoil[tool] = {
			Recoil = settings.Recoil,
			RecoilAmount = settings.RecoilAmount,
			CameraRecoil = settings.CameraRecoil,
			GunRecoil = settings.GunRecoil,
			RecoilSpeed = settings.RecoilSpeed,
			RecoilKick = settings.RecoilKick
		}
	end

	if getgenv().CertifiedReduceRecoil then
		settings.Recoil = 0
		settings.RecoilAmount = 0
		settings.CameraRecoil = 0
		settings.GunRecoil = 0
		settings.RecoilSpeed = 0
		settings.RecoilKick = 0
	else
		local old = getgenv().CertifiedOriginalRecoil[tool]
		if old then
			settings.Recoil = old.Recoil
			settings.RecoilAmount = old.RecoilAmount
			settings.CameraRecoil = old.CameraRecoil
			settings.GunRecoil = old.GunRecoil
			settings.RecoilSpeed = old.RecoilSpeed
			settings.RecoilKick = old.RecoilKick
		end
	end
end

local function ApplyReduceRecoil()
	local char = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")

	if backpack then
		for _, tool in ipairs(backpack:GetChildren()) do
			HandleRecoilTool(tool)
		end
	end

	if char then
		for _, tool in ipairs(char:GetChildren()) do
			HandleRecoilTool(tool)
		end
	end
end

local function WatchContainer(container)
	if not container then return end
	if getgenv().CertifiedRecoilConnections[container] then return end

	getgenv().CertifiedRecoilConnections[container] = container.ChildAdded:Connect(function(child)
		task.wait(0.1)
		HandleRecoilTool(child)
	end)
end

