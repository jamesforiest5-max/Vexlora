getgenv().GetAnimationHumanoid = function()
	local character = getgenv().player.Character or getgenv().player.CharacterAdded:Wait()
	return character:FindFirstChildOfClass("Humanoid")
end

getgenv().StopCurrentAnimation = function()
	if getgenv().CurrentAnimationTrack then
		pcall(function()
			getgenv().CurrentAnimationTrack:Stop(0.15)
			getgenv().CurrentAnimationTrack:Destroy()
		end)

		getgenv().CurrentAnimationTrack = nil
	end
end

getgenv().StopOtherAnimations = function(humanoid)
	if not humanoid then return end

	for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
		pcall(function()
			track:Stop(0.15)
		end)
	end
end

getgenv().PlaySelectedAnimation = function()
	local humanoid = getgenv().GetAnimationHumanoid()
	if not humanoid then return end

	local animId = getgenv().AnimationList[getgenv().SelectedAnimation]
	if not animId then return end

	getgenv().StopCurrentAnimation()
	getgenv().StopOtherAnimations(humanoid)

	local animator = humanoid:FindFirstChildOfClass("Animator")

	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end

	local animation = Instance.new("Animation")
	animation.AnimationId = animId

	local success, track = pcall(function()
		return animator:LoadAnimation(animation)
	end)

	if not success or not track then return end

	track.Priority = Enum.AnimationPriority.Action
	track.Looped = true
	track:Play(0.15, 1, 1)

	getgenv().CurrentAnimationTrack = track
end

LockerTab:Dropdown({
	Title = "Select Animation",
	Values = getgenv().AnimationNames,
	Value = "Irish Emote",

	Callback = function(option)
		getgenv().SelectedAnimation = option

		if getgenv().AnimationPlaying then
			getgenv().PlaySelectedAnimation()
		end
	end
})

LockerTab:Toggle({
	Title = "Play / Stop",
	Value = false,

	Callback = function(value)
		getgenv().AnimationPlaying = value

		if value then
			getgenv().PlaySelectedAnimation()
		else
			getgenv().StopCurrentAnimation()
		end
	end
})

