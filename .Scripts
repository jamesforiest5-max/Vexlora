local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedInstantEquip = false
getgenv().CertifiedOriginalEquipTimes = getgenv().CertifiedOriginalEquipTimes or {}
getgenv().CertifiedInstantEquipConnections = getgenv().CertifiedInstantEquipConnections or {}

local function HandleInstantEquipTool(tool)
	if not tool or not tool:IsA("Tool") then return end

	local settingModule = tool:FindFirstChild("Setting")
	if not settingModule then return end

	local success, setting = pcall(require, settingModule)
	if not success or type(setting) ~= "table" then return end

	if getgenv().CertifiedOriginalEquipTimes[tool] == nil then
		getgenv().CertifiedOriginalEquipTimes[tool] = setting.EquipTime or 0
	end

	if getgenv().CertifiedInstantEquip then
		setting.EquipTime = 0
	else
		setting.EquipTime = getgenv().CertifiedOriginalEquipTimes[tool] or 0
	end
end

local function ApplyInstantEquip()
	local char = LocalPlayer.Character
	local backpack = LocalPlayer:FindFirstChild("Backpack")

	if backpack then
		for _, tool in ipairs(backpack:GetChildren()) do
			HandleInstantEquipTool(tool)
		end
	end

	if char then
		for _, tool in ipairs(char:GetChildren()) do
			HandleInstantEquipTool(tool)
		end
	end
end

local function WatchContainer(container)
	if not container then return end
	if getgenv().CertifiedInstantEquipConnections[container] then return end

	getgenv().CertifiedInstantEquipConnections[container] = container.ChildAdded:Connect(function(child)
		task.wait(0.1)
		HandleInstantEquipTool(child)
	end)
end

