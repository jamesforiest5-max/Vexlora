local Workspace = game:GetService("Workspace")

getgenv().InstantInteractEnabled = false
getgenv().InstantInteractConnection = nil
getgenv().OriginalPromptDurations = getgenv().OriginalPromptDurations or {}

local function UpdatePrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") then return end

    if getgenv().OriginalPromptDurations[prompt] == nil then
        getgenv().OriginalPromptDurations[prompt] = prompt.HoldDuration
    end

    if getgenv().InstantInteractEnabled then
        prompt.HoldDuration = 0
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, 15)
    else
        prompt.HoldDuration = getgenv().OriginalPromptDurations[prompt] or 2
    end
end

local function UpdateAllPrompts()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            UpdatePrompt(v)
        end
    end
end

PlayerTab:Toggle({
    Title = "Instant Interact",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().InstantInteractEnabled = state
        UpdateAllPrompts()

        if state then
            if getgenv().InstantInteractConnection then
                getgenv().InstantInteractConnection:Disconnect()
            end

            getgenv().InstantInteractConnection = Workspace.DescendantAdded:Connect(function(descendant)
                if descendant:IsA("ProximityPrompt") then
                    task.wait()
                    UpdatePrompt(descendant)
                end
            end)
        else
            if getgenv().InstantInteractConnection then
                getgenv().InstantInteractConnection:Disconnect()
                getgenv().InstantInteractConnection = nil
            end

            UpdateAllPrompts()
        end
    end
})

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedDisableBlood = false
getgenv().CertifiedBloodConnections = getgenv().CertifiedBloodConnections or {}

local function IsBloodObject(obj)
    local name = obj.Name:lower()

    return name:find("blood")
        or name:find("damage")
        or name:find("hurt")
        or name:find("red")
end

local function RemoveBlood()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end

    for _, obj in ipairs(playerGui:GetDescendants()) do
        if IsBloodObject(obj) then
            pcall(function()
                obj:Destroy()
            end)
        end
    end
end

local function DisconnectBloodConnections()
    for _, connection in ipairs(getgenv().CertifiedBloodConnections) do
        pcall(function()
            connection:Disconnect()
        end)
    end

    table.clear(getgenv().CertifiedBloodConnections)
end

local function StartBloodCleaner()
    DisconnectBloodConnections()
    RemoveBlood()

    local playerGui = LocalPlayer:WaitForChild("PlayerGui")

    table.insert(getgenv().CertifiedBloodConnections, playerGui.DescendantAdded:Connect(function(obj)
        if getgenv().CertifiedDisableBlood and IsBloodObject(obj) then
            task.wait()
            pcall(function()
                obj:Destroy()
            end)
        end
    end))

    table.insert(getgenv().CertifiedBloodConnections, task.spawn(function()
        while getgenv().CertifiedDisableBlood do
            RemoveBlood()
            task.wait(1)
        end
    end))
end

PlayerTab:Toggle({
    Title = "Disable Blood",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedDisableBlood = state

        if state then
            StartBloodCleaner()
        else
            DisconnectBloodConnections()
        end
    end
})

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(1)

    if getgenv().CertifiedDisableBlood then
        StartBloodCleaner()
    end
end)

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedAntiKnockback = false
getgenv().CertifiedNoCameraBobbing = false

getgenv().AntiKnockbackConnection = nil
getgenv().AntiKnockbackThread = nil
getgenv().NoCameraBobbingThread = nil

local function IsKnockbackObject(v)
    return v:IsA("BodyVelocity")
        or v:IsA("LinearVelocity")
        or v:IsA("VectorForce")
        or v:IsA("BodyForce")
        or v:IsA("BodyPosition")
        or v:IsA("BodyGyro")
end

local function RemoveKnockbackObjects(character)
    if not character then return end

    for _, v in ipairs(character:GetDescendants()) do
        if IsKnockbackObject(v) then
            pcall(function()
                v:Destroy()
            end)
        end
    end
end

local function StartAntiKnockback()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    character:WaitForChild("HumanoidRootPart", 5)

    RemoveKnockbackObjects(character)

    if getgenv().AntiKnockbackConnection then
        getgenv().AntiKnockbackConnection:Disconnect()
        getgenv().AntiKnockbackConnection = nil
    end

    getgenv().AntiKnockbackConnection = character.DescendantAdded:Connect(function(des)
        if getgenv().CertifiedAntiKnockback and IsKnockbackObject(des) then
            task.wait()
            pcall(function()
                des:Destroy()
            end)
        end
    end)

    if getgenv().AntiKnockbackThread then return end

    getgenv().AntiKnockbackThread = task.spawn(function()
        while getgenv().CertifiedAntiKnockback do
            local char = LocalPlayer.Character
            if char then
                RemoveKnockbackObjects(char)
            end
            task.wait(0.1)
        end

        getgenv().AntiKnockbackThread = nil
    end)
end

local function StopAntiKnockback()
    getgenv().CertifiedAntiKnockback = false

    if getgenv().AntiKnockbackConnection then
        getgenv().AntiKnockbackConnection:Disconnect()
        getgenv().AntiKnockbackConnection = nil
    end
end

local function RemoveCameraEffects()
    local character = LocalPlayer.Character
    if not character then return end

    for _, v in ipairs(character:GetDescendants()) do
        local name = v.Name:lower()

        if name == "camerabobbing"
            or name == "camerashake"
            or name == "headbob"
            or name == "bobbing"
            or name:find("camera")
            or name:find("bob")
            or name:find("shake")
        then
            pcall(function()
                v:Destroy()
            end)
        end
    end
end

local function StartNoCameraBobbing()
    RemoveCameraEffects()

    if getgenv().NoCameraBobbingThread then return end

    getgenv().NoCameraBobbingThread = task.spawn(function()
        while getgenv().CertifiedNoCameraBobbing do
            pcall(RemoveCameraEffects)
            task.wait(0.25)
        end

        getgenv().NoCameraBobbingThread = nil
    end)
end

local function StopNoCameraBobbing()
    getgenv().CertifiedNoCameraBobbing = false
end

PlayerTab:Toggle({
    Title = "No Knockback",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedAntiKnockback = state

        if state then
            StartAntiKnockback()
        else
            StopAntiKnockback()
        end
    end
})

PlayerTab:Toggle({
    Title = "No Camera Bobbing",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedNoCameraBobbing = state

        if state then
            StartNoCameraBobbing()
        else
            StopNoCameraBobbing()
        end
    end
})

LocalPlayer.CharacterAdded:Connect(function(character)
    task.wait(1)

    if getgenv().CertifiedAntiKnockback then
        StartAntiKnockback()
    end

    if getgenv().CertifiedNoCameraBobbing then
        StartNoCameraBobbing()
    end
end)

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local humanoidRootPart

getgenv().CollectDroppedLoot = false
getgenv().CollectDroppedLootThread = nil

LocalPlayer.CharacterAdded:Connect(function(char)
    humanoidRootPart = char:WaitForChild("HumanoidRootPart", 10)
end)

local function updateCharacterReferences()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
    return character, humanoidRootPart
end

local function Teleportt(cframe)
    local character, root = updateCharacterReferences()
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    if not root or not humanoid or not cframe then return end

    getgenv().SwimMethod = true

    humanoid:ChangeState(0)

    repeat
        task.wait(0.0001)
    until not LocalPlayer:GetAttribute("LastACPos")

    root.CFrame = cframe

    task.wait()
    humanoid:ChangeState(2)

    getgenv().SwimMethod = false
end

local function DoCollectDroppedLoot()
    if not getgenv().CollectDroppedLoot then return end

    local char, root = updateCharacterReferences()
    if not char or not root then return end
    if not Workspace:FindFirstChild("Storage") then return end

    local oldCF = root.CFrame

    pcall(function()
        for _, v in ipairs(Workspace.Storage:GetChildren()) do
            if not getgenv().CollectDroppedLoot then break end

            if v:IsA("MeshPart") then
                local owner = v:FindFirstChild("PlayerName")
                local prompt = v:FindFirstChild("stealprompt")

                if owner and owner.Value == LocalPlayer.Name then
                    continue
                end

                if prompt and prompt:IsA("ProximityPrompt") then
                    Teleportt(v.CFrame + Vector3.new(0, 3.5, 0))
                    task.wait(0.4)

                    local oldHold = prompt.HoldDuration
                    local oldDistance = prompt.MaxActivationDistance
                    local oldLOS = prompt.RequiresLineOfSight

                    prompt.HoldDuration = 0
                    prompt.MaxActivationDistance = 50
                    prompt.RequiresLineOfSight = false

                    fireproximityprompt(prompt)

                    prompt.HoldDuration = oldHold
                    prompt.MaxActivationDistance = oldDistance
                    prompt.RequiresLineOfSight = oldLOS

                    task.wait(0.25)
                end
            end
        end
    end)

    pcall(function()
        Teleportt(oldCF)
    end)
end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().NoRentPayEnabled = false
getgenv().NoRentPayThread = nil
getgenv().NoRentPayConnection = nil

local function RemoveRentGui()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end

    local rentGui = playerGui:FindFirstChild("RentGui")
    if rentGui then
        pcall(function()
            rentGui:Destroy()
        end)
    end
end

local function StartNoRentPay()
    RemoveRentGui()

    if getgenv().NoRentPayConnection then
        getgenv().NoRentPayConnection:Disconnect()
        getgenv().NoRentPayConnection = nil
    end

    local playerGui = LocalPlayer:WaitForChild("PlayerGui")

    getgenv().NoRentPayConnection = playerGui.ChildAdded:Connect(function(child)
        if getgenv().NoRentPayEnabled and child.Name == "RentGui" then
            task.wait()
            pcall(function()
                child:Destroy()
            end)
        end
    end)

    if getgenv().NoRentPayThread then return end

    getgenv().NoRentPayThread = task.spawn(function()
        while getgenv().NoRentPayEnabled do
            RemoveRentGui()
            task.wait(1)
        end

        getgenv().NoRentPayThread = nil
    end)
end

local function StopNoRentPay()
    getgenv().NoRentPayEnabled = false

    if getgenv().NoRentPayConnection then
        getgenv().NoRentPayConnection:Disconnect()
        getgenv().NoRentPayConnection = nil
    end
end

PlayerTab:Toggle({
    Title = "No Rent Pay",
    Value = false,

    Callback = function(state)
        getgenv().NoRentPayEnabled = state

        if state then
            StartNoRentPay()
        else
            StopNoRentPay()
        end
    end
})

PlayerTab:Toggle({
    Title = "Auto Pickup Bags",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CollectDroppedLoot = state

        if state then
            if getgenv().CollectDroppedLootThread then return end

            getgenv().CollectDroppedLootThread = task.spawn(function()
                while getgenv().CollectDroppedLoot do
                    pcall(DoCollectDroppedLoot)
                    task.wait(0.5)
                end

                getgenv().CollectDroppedLootThread = nil
            end)
        else
            getgenv().CollectDroppedLoot = false
        end
    end
})

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

getgenv().CertifiedInstantRespawn = false
getgenv().CertifiedRespawnWhereDied = false

getgenv().InstantRespawnThread = nil
getgenv().DeathConnection = nil
getgenv().RespawnConnection = nil
getgenv().LastDeathCFrame = nil

local function FireRespawn()
    local respawnRemote = ReplicatedStorage:FindFirstChild("RespawnRE")
    if respawnRemote then
        respawnRemote:FireServer()
    end
end

local function StartInstantRespawn()
    if getgenv().InstantRespawnThread then return end

    getgenv().InstantRespawnThread = task.spawn(function()
        while getgenv().CertifiedInstantRespawn do
            local character = LocalPlayer.Character
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")

            if humanoid and humanoid.Health <= 0 then
                FireRespawn()
            end

            task.wait(0.25)
        end

        getgenv().InstantRespawnThread = nil
    end)
end

local function SetupRespawnWhereDied(character)
    if getgenv().DeathConnection then
        getgenv().DeathConnection:Disconnect()
        getgenv().DeathConnection = nil
    end

    character = character or LocalPlayer.Character
    if not character then return end

    local humanoid = character:WaitForChild("Humanoid", 5)
    local root = character:WaitForChild("HumanoidRootPart", 5)

    if not humanoid or not root then return end

    getgenv().DeathConnection = humanoid.Died:Connect(function()
        if getgenv().CertifiedRespawnWhereDied and root then
            getgenv().LastDeathCFrame = root.CFrame
        end
    end)
end

local function StartRespawnWhereDied()
    SetupRespawnWhereDied(LocalPlayer.Character)

    if getgenv().RespawnConnection then
        getgenv().RespawnConnection:Disconnect()
        getgenv().RespawnConnection = nil
    end

    getgenv().RespawnConnection = LocalPlayer.CharacterAdded:Connect(function(character)
        task.wait(0.5)

        local root = character:WaitForChild("HumanoidRootPart", 5)

        if getgenv().CertifiedRespawnWhereDied and root and getgenv().LastDeathCFrame then
            root.CFrame = getgenv().LastDeathCFrame
        end

        if getgenv().CertifiedRespawnWhereDied then
            SetupRespawnWhereDied(character)
        end
    end)
end

local function StopRespawnWhereDied()
    if getgenv().DeathConnection then
        getgenv().DeathConnection:Disconnect()
        getgenv().DeathConnection = nil
    end

    if getgenv().RespawnConnection then
        getgenv().RespawnConnection:Disconnect()
        getgenv().RespawnConnection = nil
    end

    getgenv().LastDeathCFrame = nil
end

PlayerTab:Toggle({
    Title = "Quick Respawn",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedInstantRespawn = state

        if state then
            StartInstantRespawn()
        end
    end
})

PlayerTab:Toggle({
    Title = "Respawn Where Died",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().CertifiedRespawnWhereDied = state

        if state then
            StartRespawnWhereDied()
        else
            StopRespawnWhereDied()
        end
    end
})

PrecumTab:Section({
    Title = "👥  Players"
})

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

getgenv().PrecumSelectedPlayer = nil
getgenv().SwimMethod = false

getgenv().PrecumGetPlayers = function()
	local list = {}

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			table.insert(list, player.Name)
		end
	end

	table.sort(list)
	return list
end

getgenv().PrecumUpdateCharacterReferences = function()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local root = character:WaitForChild("HumanoidRootPart", 10)
	local humanoid = character:FindFirstChildOfClass("Humanoid")

	return character, root, humanoid
end

getgenv().PrecumTeleport = function(cframe)
	local character, root, humanoid = getgenv().PrecumUpdateCharacterReferences()

	if not character or not root or not humanoid then
		return
	end

	getgenv().SwimMethod = true

	pcall(function()
		humanoid:ChangeState(0)
	end)

	local timeout = tick() + 2

	repeat
		task.wait()
	until not LocalPlayer:GetAttribute("LastACPos") or tick() > timeout

	root.CFrame = cframe

	task.wait(0.1)

	pcall(function()
		humanoid:ChangeState(2)
	end)

	getgenv().SwimMethod = false
end

getgenv().PrecumTeleportToPlayer = function(targetPlayer)
	if not targetPlayer then return end

	local character = targetPlayer.Character
	if not character then return end

	local targetRoot = character:FindFirstChild("HumanoidRootPart")
	if not targetRoot then return end

	local position = targetRoot.Position + (targetRoot.CFrame.LookVector * 3)

	getgenv().PrecumTeleport(
		CFrame.new(position, targetRoot.Position)
	)
end

getgenv().PrecumPlayerDropdown = PrecumTab:Dropdown({
	Title = "Select Player",
	Values = getgenv().PrecumGetPlayers(),
	Value = "",

	Callback = function(Value)
		getgenv().PrecumSelectedPlayer = Value
	end
})

getgenv().PrecumRefreshPlayers = function()
	local players = getgenv().PrecumGetPlayers()

	if getgenv().PrecumPlayerDropdown then
		pcall(function()
			getgenv().PrecumPlayerDropdown:Refresh(players, true)
		end)
	end
end

PrecumTab:Button({
