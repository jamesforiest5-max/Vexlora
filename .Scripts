local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

getgenv().RainbowGunEnabled = false
getgenv().RainbowGunOriginalData = getgenv().RainbowGunOriginalData or {}
getgenv().RainbowGunToolConnection = nil
getgenv().RainbowGunRenderConnection = nil
getgenv().RainbowGunCharacterConnection = nil

local function SavePartData(part)
    if not getgenv().RainbowGunOriginalData[part] then
        getgenv().RainbowGunOriginalData[part] = {
            Color = part.Color,
            Material = part.Material
        }
    end
end

local function ApplyRainbowGun(tool)
    if not tool or not tool:IsA("Tool") then return end

    for _, part in ipairs(tool:GetDescendants()) do
        if part:IsA("BasePart") then
            SavePartData(part)
            part.Material = Enum.Material.Neon
        end
    end
end

local function ApplyCurrentTool()
    local character = LocalPlayer.Character
    if not character then return end

    local tool = character:FindFirstChildOfClass("Tool")
    if tool then
        ApplyRainbowGun(tool)
    end
end

local function RevertRainbowGun()
    for part, data in pairs(getgenv().RainbowGunOriginalData) do
        if part and part.Parent then
            pcall(function()
                part.Color = data.Color
                part.Material = data.Material
            end)
        end
    end

    table.clear(getgenv().RainbowGunOriginalData)
end

local function DisconnectRainbowGun()
    if getgenv().RainbowGunToolConnection then
        getgenv().RainbowGunToolConnection:Disconnect()
        getgenv().RainbowGunToolConnection = nil
    end

    if getgenv().RainbowGunRenderConnection then
        getgenv().RainbowGunRenderConnection:Disconnect()
        getgenv().RainbowGunRenderConnection = nil
    end

    if getgenv().RainbowGunCharacterConnection then
        getgenv().RainbowGunCharacterConnection:Disconnect()
        getgenv().RainbowGunCharacterConnection = nil
    end
end

local function StartRainbowGun()
    DisconnectRainbowGun()
    ApplyCurrentTool()

    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

    getgenv().RainbowGunToolConnection = character.ChildAdded:Connect(function(child)
        if getgenv().RainbowGunEnabled and child:IsA("Tool") then
            task.wait(0.1)
            ApplyRainbowGun(child)
        end
    end)

    getgenv().RainbowGunRenderConnection = RunService.RenderStepped:Connect(function()
        if not getgenv().RainbowGunEnabled then return end

        local hue = (tick() % 5) / 5
        local color = Color3.fromHSV(hue, 1, 1)

        for part, _ in pairs(getgenv().RainbowGunOriginalData) do
            if part and part.Parent then
                part.Color = color
            end
        end
    end)

    getgenv().RainbowGunCharacterConnection = LocalPlayer.CharacterAdded:Connect(function(character)
        task.wait(1)

        if getgenv().RainbowGunEnabled then
            StartRainbowGun()
        end
    end)
end

local function StopRainbowGun()
    getgenv().RainbowGunEnabled = false
    DisconnectRainbowGun()
    RevertRainbowGun()
end

TargetTab:Toggle({
    Title = "Rainbow Gun",
    Locked = false,
    Value = false,

    Callback = function(state)
        getgenv().RainbowGunEnabled = state

        if state then
            StartRainbowGun()
        else
            StopRainbowGun()
        end
    end
})

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local Debris = game:GetService("Debris")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

--// SETTINGS
getgenv().CertifiedImpactEnabled = false
getgenv().CertifiedFlameEnabled = false

local ImageID = "rbxthumb://type=Asset&id=83113397492464&w=420&h=420"

--// Bullet Graffiti
local function SpawnImageAt(position, normal)
	local character = LocalPlayer.Character

	local holder = Instance.new("Part")
	holder.Name = "CertifiedImpact"
	holder.Anchored = true
	holder.CanCollide = false
	holder.CanQuery = false
	holder.CanTouch = false
	holder.Transparency = 1
	holder.Size = Vector3.new(8, 8, 0.05)

	holder.CFrame = CFrame.lookAt(
		position + normal * 0.08,
		position + normal
	)

	holder.Parent = Workspace

	local surface = Instance.new("SurfaceGui")
	surface.Face = Enum.NormalId.Front
	surface.AlwaysOnTop = false -- stops it showing through your body
	surface.LightInfluence = 0
	surface.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	surface.PixelsPerStud = 60
	surface.Parent = holder

	local image = Instance.new("ImageLabel")
	image.BackgroundTransparency = 1
	image.Size = UDim2.fromScale(1, 1)
	image.Image = ImageID
	image.Parent = surface

	Debris:AddItem(holder, 10)
end

local function ShootGraffiti()
	if not getgenv().CertifiedImpactEnabled then return end

	local character = LocalPlayer.Character
	if not character then return end

	local tool = character:FindFirstChildOfClass("Tool")
	if not tool then return end

	local mousePos = UIS:GetMouseLocation()
	local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {character}
	params.IgnoreWater = true

	local result = Workspace:Raycast(ray.Origin, ray.Direction * 1000, params)

	if result and not result.Instance:IsDescendantOf(character) then
		SpawnImageAt(result.Position, result.Normal)
	end
end

UIS.InputBegan:Connect(function(input, gp)
	if gp then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		ShootGraffiti()
	end
end)

-- Bullet Flamethrower Trail
local GunFireEnabled = false
local HookedTools = {}
local LastShotTime = 0
local CurrentMuzzle = nil

local MAX_BARREL_DISTANCE = 18
local SHOT_WINDOW = 0.4

local function GetMuzzlePart(tool)
	for _, v in ipairs(tool:GetDescendants()) do
		local n = v.Name:lower()

		if v:IsA("Attachment") and (n:find("muzzle") or n:find("barrel") or n:find("fire")) then
			return v
		end

		if v:IsA("BasePart") and (n:find("muzzle") or n:find("barrel") or n:find("handle")) then
			return v
		end
	end

	return tool:FindFirstChild("Handle")
end

local function GetMuzzlePosition()
	if not CurrentMuzzle then return nil end

	if CurrentMuzzle:IsA("Attachment") then
		return CurrentMuzzle.WorldPosition
	elseif CurrentMuzzle:IsA("BasePart") then
		return CurrentMuzzle.Position
	end
end

local function AddFlamethrowerTrail(bullet)
	if not GunFireEnabled then return end
	if not bullet or not bullet:IsA("BasePart") then return end
	if bullet:FindFirstChild("ScorpioFlameTrail") then return end

	local a0 = Instance.new("Attachment", bullet)
	a0.Name = "FlameA0"
	a0.Position = Vector3.new(0, 1, 0)

	local a1 = Instance.new("Attachment", bullet)
	a1.Name = "FlameA1"
	a1.Position = Vector3.new(0, -1, 0)

	local trail = Instance.new("Trail")
	trail.Name = "ScorpioFlameTrail"
	trail.Attachment0 = a0
	trail.Attachment1 = a1
	trail.Texture = "rbxassetid://248625108"
	trail.FaceCamera = true
	trail.LightEmission = 1
	trail.LightInfluence = 0
	trail.Lifetime = 1.5
	trail.MinLength = 0.01
	trail.WidthScale = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 5),
		NumberSequenceKeypoint.new(0.5, 4),
		NumberSequenceKeypoint.new(1, 0)
	})
	trail.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 200)),
		ColorSequenceKeypoint.new(0.3, Color3.fromRGB(255, 180, 0)),
		ColorSequenceKeypoint.new(0.7, Color3.fromRGB(255, 80, 0)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 0, 0))
	})
	trail.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(0.8, 0.15),
		NumberSequenceKeypoint.new(1, 1)
	})
	trail.Parent = bullet

	local flame = Instance.new("ParticleEmitter")
	flame.Name = "ScorpioBeamFlame"
	flame.Texture = "rbxassetid://248625108"
	flame.Rate = 300
	flame.Lifetime = NumberRange.new(1, 2)
	flame.Speed = NumberRange.new(0, 2)
	flame.LightEmission = 1
	flame.SpreadAngle = Vector2.new(180, 180)
	flame.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 3),
		NumberSequenceKeypoint.new(0.5, 2),
		NumberSequenceKeypoint.new(1, 0)
	})
	flame.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 150)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 120, 0)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
	})
	flame.Parent = bullet

	Debris:AddItem(a0, 5)
	Debris:AddItem(a1, 5)
	Debris:AddItem(trail, 5)
	Debris:AddItem(flame, 5)
end

local function HookTool(tool)
	if HookedTools[tool] then return end
	HookedTools[tool] = true

	tool.Equipped:Connect(function()
		CurrentMuzzle = GetMuzzlePart(tool)
	end)

	tool.Unequipped:Connect(function()
		if CurrentMuzzle and CurrentMuzzle:IsDescendantOf(tool) then
			CurrentMuzzle = nil
		end
	end)

	tool.Activated:Connect(function()
		if not GunFireEnabled then return end
		CurrentMuzzle = GetMuzzlePart(tool)
		LastShotTime = os.clock()
	end)
end

local function HookCharacter(char)
	for _, v in ipairs(char:GetChildren()) do
		if v:IsA("Tool") then
			HookTool(v)
		end
	end

	char.ChildAdded:Connect(function(v)
		if v:IsA("Tool") then
			HookTool(v)
		end
	end)
end

if LocalPlayer.Character then
	HookCharacter(LocalPlayer.Character)
end

LocalPlayer.CharacterAdded:Connect(HookCharacter)

Workspace.DescendantAdded:Connect(function(obj)
	if not GunFireEnabled then return end
	if not obj:IsA("BasePart") then return end
	if os.clock() - LastShotTime > SHOT_WINDOW then return end

	local name = obj.Name:lower()

	if not (
		name:find("bullet")
		or name:find("projectile")
		or name:find("tracer")
		or name:find("ray")
	) then
		return
	end

	task.wait()

	local muzzlePos = GetMuzzlePosition()
	if not muzzlePos then return end

	if (obj.Position - muzzlePos).Magnitude <= MAX_BARREL_DISTANCE then
		AddFlamethrowerTrail(obj)
	end
end)

