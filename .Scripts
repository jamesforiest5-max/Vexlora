getgenv().ApplySettingsSkybox = function(name)
	getgenv().SkyData = getgenv().SkyboxAssets[name]
	if not getgenv().SkyData then return end

	getgenv().SkyObj = getgenv().Lighting:FindFirstChildOfClass("Sky") or Instance.new("Sky")
	getgenv().SkyObj.Parent = getgenv().Lighting

	getgenv().SkyObj.SkyboxBk = getgenv().SkyData[1]
	getgenv().SkyObj.SkyboxDn = getgenv().SkyData[2]
	getgenv().SkyObj.SkyboxFt = getgenv().SkyData[3]
	getgenv().SkyObj.SkyboxLf = getgenv().SkyData[4]
	getgenv().SkyObj.SkyboxRt = getgenv().SkyData[5]
	getgenv().SkyObj.SkyboxUp = getgenv().SkyData[6]
end

getgenv().RestoreSettingsSkybox = function()
	getgenv().SkyObj = getgenv().Lighting:FindFirstChildOfClass("Sky")
	if getgenv().SkyObj then
		getgenv().SkyObj:Destroy()
	end
end

