getgenv().killbring = false

PrecumTab:Toggle({
    Title = "Kill Bring",
    Value = false,

    Callback = function(Value)
        getgenv().killbring = Value

        if Value then
            task.spawn(function()
                while getgenv().killbring do
                local speaker = game.Players.LocalPlayer
                    local speakerChar = speaker.Character
                    local speakerRoot = speakerChar and speakerChar:FindFirstChild("HumanoidRootPart")

                    if not speakerRoot then
                        task.wait()
                        continue
                    end

                    local radius = 15
                    local players = game.Players:GetPlayers()
                    local count = math.max(#players - 1, 1)
                    local step = (2 * math.pi) / count
                    local i = 0

                    for _, target in ipairs(players) do
                        if target ~= speaker and target.Character then
                            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
                            local humanoid = target.Character:FindFirstChildOfClass("Humanoid")

                            if targetRoot then
                                if humanoid then
                                    humanoid.Sit = false
                                end

                                local angle = i * step
                                local offset = Vector3.new(
                                    math.cos(angle) * radius,
                                    1,
                                    math.sin(angle) * radius
                                )

                                targetRoot.CFrame = speakerRoot.CFrame + offset
                                i += 1
                            end
                        end
                    end

                    task.wait(0.3)
                end
            end)
        end
    end
})

getgenv().Players = game:GetService("Players")
getgenv().RunService = game:GetService("RunService")
getgenv().LocalPlayer = getgenv().Players.LocalPlayer

getgenv().RainbowNamesEnabled = false
getgenv().RainbowNameObjects = {}
getgenv().RainbowNameHue = 0

getgenv().RainbowESPEnabled = false
getgenv().RainbowHighlights = {}
getgenv().RainbowESPHue = 0

getgenv().CreateRainbowNameESP = function(plr)
	if plr == getgenv().LocalPlayer then return end

	getgenv().SetupRainbowChar = function(char)
		getgenv().Head = char:WaitForChild("Head", 5)
		if not getgenv().Head then return end

		if char:FindFirstChild("RainbowNameESP") then
			char.RainbowNameESP:Destroy()
		end

		getgenv().Billboard = Instance.new("BillboardGui")
		getgenv().Billboard.Name = "RainbowNameESP"
		getgenv().Billboard.Adornee = getgenv().Head
		getgenv().Billboard.Size = UDim2.new(0, 200, 0, 50)
		getgenv().Billboard.StudsOffset = Vector3.new(0, 2, 0)
		getgenv().Billboard.AlwaysOnTop = true
		getgenv().Billboard.Enabled = getgenv().RainbowNamesEnabled
		getgenv().Billboard.Parent = char

		getgenv().NameText = Instance.new("TextLabel")
		getgenv().NameText.BackgroundTransparency = 1
		getgenv().NameText.Size = UDim2.new(1, 0, 1, 0)
		getgenv().NameText.Font = Enum.Font.SourceSansBold
		getgenv().NameText.TextScaled = true
		getgenv().NameText.TextStrokeTransparency = 0
		getgenv().NameText.Text = plr.Name
		getgenv().NameText.Parent = getgenv().Billboard

		getgenv().RainbowNameObjects[plr] = {
			Billboard = getgenv().Billboard,
			Label = getgenv().NameText
		}
	end

	if plr.Character then
		getgenv().SetupRainbowChar(plr.Character)
	end

	plr.CharacterAdded:Connect(function(char)
		task.wait(1)
		getgenv().SetupRainbowChar(char)
	end)
end

getgenv().AddRainbowHighlight = function(char)
	if getgenv().RainbowHighlights[char] then return end

	getgenv().RainbowHighlight = Instance.new("Highlight")
	getgenv().RainbowHighlight.Name = "RainbowESP"
	getgenv().RainbowHighlight.FillTransparency = 0.4
	getgenv().RainbowHighlight.OutlineTransparency = 1
	getgenv().RainbowHighlight.Enabled = getgenv().RainbowESPEnabled
	getgenv().RainbowHighlight.Parent = char

	getgenv().RainbowHighlights[char] = getgenv().RainbowHighlight
end

getgenv().RemoveRainbowHighlight = function(char)
	if getgenv().RainbowHighlights[char] then
		getgenv().RainbowHighlights[char]:Destroy()
		getgenv().RainbowHighlights[char] = nil
	end
end

getgenv().UpdateRainbowESP = function()
	if getgenv().RainbowESPEnabled then
		for _, plr in ipairs(getgenv().Players:GetPlayers()) do
			if plr ~= getgenv().LocalPlayer and plr.Character then
				getgenv().AddRainbowHighlight(plr.Character)
			end
		end
	else
		for char in pairs(getgenv().RainbowHighlights) do
			getgenv().RemoveRainbowHighlight(char)
		end
	end
end

for _, plr in ipairs(getgenv().Players:GetPlayers()) do
	getgenv().CreateRainbowNameESP(plr)
end

getgenv().Players.PlayerAdded:Connect(function(plr)
	getgenv().CreateRainbowNameESP(plr)
end)

PrecumTab:Toggle({
	Title = "Rainbow Names",
	Value = false,
	Callback = function(Value)
		getgenv().RainbowNamesEnabled = Value

		for _, obj in pairs(getgenv().RainbowNameObjects) do
			if obj.Billboard then
				obj.Billboard.Enabled = Value
			end
		end
	end
})

PrecumTab:Toggle({
	Title = "Rainbow ESP",
	Value = false,
	Callback = function(Value)
		getgenv().RainbowESPEnabled = Value
		getgenv().UpdateRainbowESP()
	end
})

if getgenv().RainbowESPLoop then
	getgenv().RainbowESPLoop:Disconnect()
end

getgenv().RainbowESPLoop = getgenv().RunService.RenderStepped:Connect(function()
	getgenv().RainbowNameHue = (getgenv().RainbowNameHue + 0.005) % 1
	getgenv().RainbowESPHue = (getgenv().RainbowESPHue + 0.005) % 1

	getgenv().RainbowNameColor = Color3.fromHSV(getgenv().RainbowNameHue, 1, 1)
	getgenv().RainbowESPColor = Color3.fromHSV(getgenv().RainbowESPHue, 1, 1)

	for _, obj in pairs(getgenv().RainbowNameObjects) do
		if obj.Billboard then
			obj.Billboard.Enabled = getgenv().RainbowNamesEnabled
		end

		if obj.Label then
			obj.Label.TextColor3 = getgenv().RainbowNameColor
		end
	end

	if getgenv().RainbowESPEnabled then
		getgenv().UpdateRainbowESP()

		for _, h in pairs(getgenv().RainbowHighlights) do
			if h then
				h.Enabled = true
				h.FillColor = getgenv().RainbowESPColor
			end
		end
	end
end)

LolTab:Section({
	Title = "💵  Auto Farms"
})

getgenv().ConstructionFarming = false
getgenv().ConstructionFarmThread = nil
getgenv().ConstructionLP = game.Players.LocalPlayer

getgenv().GetWallSpot = function()
	for _, v in pairs(workspace:WaitForChild("ConstructionStuff"):GetChildren()) do
		if v:IsA("Part") and v.Name:find("Wall") then
			local prompt = v:FindFirstChild("Prompt")
			if prompt and prompt.Enabled then
				return v
			end
		end
	end

	return nil
end

getgenv().ConstructionTP = function(cf)
	local char = getgenv().ConstructionLP.Character or getgenv().ConstructionLP.CharacterAdded:Wait()
	local hum = char:WaitForChild("Humanoid")
	local hrp = char:WaitForChild("HumanoidRootPart")

	hum:ChangeState(0)

	local timeout = 0
	while getgenv().ConstructionLP:GetAttribute("LastACPos") and timeout < 2 do
		timeout += task.wait()
	end

	hrp.CFrame = cf
	task.wait(0.1)
	hum:ChangeState(2)
end

getgenv().ConstructionFarmLoop = function()
	while getgenv().ConstructionFarming do
		local char = getgenv().ConstructionLP.Character or getgenv().ConstructionLP.CharacterAdded:Wait()
		local hum = char:FindFirstChild("Humanoid")

		if not hum or hum.Health <= 0 then
			task.wait(0.5)
			continue
		end

		if not getgenv().ConstructionLP:GetAttribute("WorkingJob") then
			getgenv().ConstructionTP(CFrame.new(-1729, 371, -1171))
			task.wait(0.3)

			local start = workspace.ConstructionStuff:FindFirstChild("Start Job")
			if start and start:FindFirstChild("Prompt") then
				fireproximityprompt(start.Prompt)
			end

			repeat
				task.wait()
			until getgenv().ConstructionLP:GetAttribute("WorkingJob") or not getgenv().ConstructionFarming
		end

		local hasWood = getgenv().ConstructionLP.Backpack:FindFirstChild("PlyWood") or char:FindFirstChild("PlyWood")

		if not hasWood then
			getgenv().ConstructionTP(CFrame.new(-1728, 371, -1178))

			local grab = workspace.ConstructionStuff:FindFirstChild("Grab Wood")

			repeat
				task.wait()

				if grab and grab:FindFirstChild("Prompt") then
					fireproximityprompt(grab.Prompt)
				end

				hasWood = getgenv().ConstructionLP.Backpack:FindFirstChild("PlyWood") or char:FindFirstChild("PlyWood")
			until hasWood or not getgenv().ConstructionFarming
		end

		local tool = getgenv().ConstructionLP.Backpack:FindFirstChild("PlyWood")
		if tool then
			char.Humanoid:EquipTool(tool)
		end

		local spot = getgenv().GetWallSpot()
		if not spot then
			task.wait(0.3)
			continue
		end

		getgenv().ConstructionTP(spot.CFrame)

		repeat
			task.wait()

			if spot:FindFirstChild("Prompt") then
				fireproximityprompt(spot.Prompt)
			end
		until not char:FindFirstChild("PlyWood")
			or not spot:FindFirstChild("Prompt")
			or not spot.Prompt.Enabled
			or not getgenv().ConstructionFarming

		task.wait(0.15)
	end
end

LolTab:Toggle({
	Title = "Construction",
	Desc = "Auto construction job",
	Value = false,
	Callback = function(Value)
		getgenv().ConstructionFarming = Value

		if Value then
			if not getgenv().ConstructionFarmThread then
				getgenv().ConstructionFarmThread = task.spawn(function()
					local success, err = pcall(getgenv().ConstructionFarmLoop)
					if not success then
						warn("Construction crashed:", err)
					end

					getgenv().ConstructionFarmThread = nil
				end)
			end
		else
			if getgenv().ConstructionFarmThread then
				task.cancel(getgenv().ConstructionFarmThread)
				getgenv().ConstructionFarmThread = nil
			end
		end
	end
})

getgenv().FarmStudio = false
getgenv().SwimMethod = false

LolTab:Toggle({
	Title = "Auto Studio",
    Desc = "Automatically completes if available",
	Value = false,

	Callback = function(state)
		getgenv().FarmStudio = state
	end
})

getgenv().UpdateCharacterReferences = function()
	getgenv().StudioCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	getgenv().StudioRoot = getgenv().StudioCharacter:WaitForChild("HumanoidRootPart", 10)
	getgenv().StudioHumanoid = getgenv().StudioCharacter:FindFirstChildOfClass("Humanoid")

	return getgenv().StudioCharacter, getgenv().StudioRoot, getgenv().StudioHumanoid
end

getgenv().StudioTeleport = function(cframe)
	getgenv().StudioCharacter, getgenv().StudioRoot, getgenv().StudioHumanoid = getgenv().UpdateCharacterReferences()

	if not getgenv().StudioCharacter or not getgenv().StudioRoot or not getgenv().StudioHumanoid or not cframe then
		return
	end

	getgenv().SwimMethod = true

	pcall(function()
		getgenv().StudioHumanoid:ChangeState(0)
	end)

	getgenv().StudioTimeout = tick() + 1

	repeat
		task.wait()
	until not LocalPlayer:GetAttribute("LastACPos") or tick() > getgenv().StudioTimeout

	getgenv().StudioRoot.CFrame = cframe
	task.wait(0.1)

	pcall(function()
		getgenv().StudioHumanoid:ChangeState(1)
	end)

	getgenv().SwimMethod = false
end

task.spawn(function()
	while true do
		task.wait()

		if not getgenv().FarmStudio then
			continue
		end

		getgenv().StudioChar = LocalPlayer.Character
		if not getgenv().StudioChar or not getgenv().StudioChar:FindFirstChild("HumanoidRootPart") then
			continue
		end

		getgenv().StudioHum = getgenv().StudioChar:FindFirstChild("Humanoid")
		if not getgenv().StudioHum or getgenv().StudioHum.Health <= 0 then
			continue
		end

		pcall(function()
			getgenv().StudioP1 = Workspace.StudioPay.Money.StudioPay1:FindFirstChild("Prompt", true)
			getgenv().StudioP2 = Workspace.StudioPay.Money.StudioPay2:FindFirstChild("Prompt", true)
			getgenv().StudioP3 = Workspace.StudioPay.Money.StudioPay3:FindFirstChild("Prompt", true)

			if getgenv().StudioP1 and getgenv().StudioP1.Enabled then
				getgenv().StudioTeleport(getgenv().StudioP1.Parent.CFrame)
				task.wait(0.4)
				fireproximityprompt(getgenv().StudioP1)
				task.wait(0.1)
			end

			if getgenv().StudioP2 and getgenv().StudioP2.Enabled then
				getgenv().StudioTeleport(getgenv().StudioP2.Parent.CFrame)
				task.wait(0.4)
				fireproximityprompt(getgenv().StudioP2)
				task.wait(0.1)
			end

			if getgenv().StudioP3 and getgenv().StudioP3.Enabled then
				getgenv().StudioTeleport(getgenv().StudioP3.Parent.CFrame)
				task.wait(0.4)
				fireproximityprompt(getgenv().StudioP3)
				task.wait(0.1)
			end
		end)

		task.wait(0.5)
	end
end)

