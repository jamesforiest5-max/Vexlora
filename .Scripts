getgenv().P.StartSpectate = function()
	if getgenv().P.SpectateConnection then
		getgenv().P.SpectateConnection:Disconnect()
		getgenv().P.SpectateConnection = nil
	end

	getgenv().P.SpectateConnection = getgenv().P.RunService.RenderStepped:Connect(function()
		if not getgenv().P.SpectateRunning then return end
		if not getgenv().P.SelectedPlayer or getgenv().P.SelectedPlayer == "" then return end

		getgenv().P.Target = getgenv().P.Players:FindFirstChild(getgenv().P.SelectedPlayer)
		if not getgenv().P.Target or not getgenv().P.Target.Character then return end

		getgenv().P.TargetHumanoid = getgenv().P.Target.Character:FindFirstChildWhichIsA("Humanoid")
		getgenv().P.TargetRoot = getgenv().P.Target.Character:FindFirstChild("HumanoidRootPart")

		if getgenv().P.TargetHumanoid then
			getgenv().P.Camera.CameraSubject = getgenv().P.TargetHumanoid
		elseif getgenv().P.TargetRoot then
			getgenv().P.Camera.CameraSubject = getgenv().P.TargetRoot
		end
	end)
end

