}

getgenv().AuraEnabled = false
getgenv().AuraType = "DragonBallZ"
getgenv().CurrentAuraModel = nil
getgenv().AuraEffects = {}

getgenv().LoadAuraModel = function(id)
	local success, result = pcall(function()
		return game:GetObjects(id)[1]
	end)

	if success then
		return result
	end

	return nil
end

getgenv().DisableAura = function()
	for _, v in pairs(getgenv().AuraEffects) do
		if v and v.Parent then
			v:Destroy()
		end
	end

	getgenv().AuraEffects = {}
end

getgenv().EnableAura = function(char)
	getgenv().DisableAura()

	if not getgenv().CurrentAuraModel or not char then
		return
	end

	local temp = getgenv().CurrentAuraModel:Clone()

	for _, obj in pairs(temp:GetDescendants()) do
		if not obj:IsA("BasePart") then
			local clone = obj:Clone()

			local target =
				char:FindFirstChild(obj.Parent and obj.Parent.Name)
				or char:FindFirstChild("HumanoidRootPart")
				or char:FindFirstChildWhichIsA("BasePart")

			if target then
				clone.Parent = target
				table.insert(getgenv().AuraEffects, clone)
			end
		end
	end

	temp:Destroy()
end

getgenv().UpdateAura = function()
	local id = getgenv().AuraModels[getgenv().AuraType]

	if not id then
		return
	end

	local model = getgenv().LoadAuraModel(id)

	if model then
		getgenv().CurrentAuraModel = model

		if getgenv().AuraEnabled and player.Character then
			getgenv().EnableAura(player.Character)
		end
	end
end

getgenv().AuraList = {}

for name in pairs(getgenv().AuraModels) do
	table.insert(getgenv().AuraList, name)
end

table.sort(getgenv().AuraList)

LockerTab:Toggle({
	Title = "Enable Aura",
	Value = false,

	Callback = function(Value)
		getgenv().AuraEnabled = Value

		if Value then
			getgenv().UpdateAura()
		else
			getgenv().DisableAura()
		end
	end
})

