getgenv().RainbowText = function(label)
	task.spawn(function()
		local hue = 0

		while label and label.Parent do
			hue = (hue + 0.01) % 1
			label.TextColor3 = Color3.fromHSV(hue, 1, 1)
			task.wait(0.03)
		end
	end)
end

getgenv().RemoveNameTag = function()
	if getgenv().NameTagBillboard then
		getgenv().NameTagBillboard:Destroy()
		getgenv().NameTagBillboard = nil
	end
end

getgenv().CreateNameTag = function()
	getgenv().RemoveNameTag()

	local char = player.Character or player.CharacterAdded:Wait()
	local head = char:WaitForChild("Head", 5)
	if not head then return end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "CustomRainbowTag"
	billboard.Size = UDim2.new(0, 175, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 1.5, 0)
	billboard.AlwaysOnTop = true
	billboard.Parent = head

	local text = Instance.new("TextButton")
	text.Size = UDim2.new(1, 0, 1, 0)
	text.BackgroundTransparency = 1
	text.Text = getgenv().CustomNameTag
	text.TextScaled = true
	text.Font = Enum.Font.GothamBold
	text.Parent = billboard

	getgenv().NameTagBillboard = billboard
	getgenv().RainbowText(text)
end

LockerTab:Input({
	Title = "Custom NameTag",
	Value = "",
	Placeholder = "Enter Name",

	Callback = function(Text)
		if Text ~= "" then
			getgenv().CustomNameTag = Text

			if getgenv().NameTagEnabled then
				getgenv().CreateNameTag()
			end
		end
	end
})

