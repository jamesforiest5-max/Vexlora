local AutoGEnabled = false
local AutoGThread = nil

local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

local BLOCKED_TOOLS = {
    ["Phone"] = true,
    ["Fist"] = true,
}

local function PressG()
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.G, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.G, false, game)
    end)
end

local function GetValidTools()
    local Backpack = LocalPlayer:FindFirstChild("Backpack")
    if not Backpack then return {} end

    local Tools = {}

    for _, Tool in ipairs(Backpack:GetChildren()) do
        if Tool:IsA("Tool") and not BLOCKED_TOOLS[Tool.Name] then
            table.insert(Tools, Tool)
        end
    end

    return Tools
end

local function EquipTool(Tool)
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")

    if not Character or not Humanoid or Humanoid.Health <= 0 then
        return false
    end

    Humanoid:UnequipTools()
    task.wait(0.15)

    if Tool and Tool.Parent == LocalPlayer.Backpack then
        Humanoid:EquipTool(Tool)
        task.wait(0.25)
        return true
    end

    return false
end

MainTab:Toggle({
    Title = "Auto Drop Gun",
    Locked = false,
    Value = false,

    Callback = function(state)
        AutoGEnabled = state

        if state then
            if AutoGThread then return end

            AutoGThread = task.spawn(function()
                while AutoGEnabled do
                    local Tools = GetValidTools()

                    for _, Tool in ipairs(Tools) do
                        if not AutoGEnabled then
                            break
                        end

                        if EquipTool(Tool) then
                            local StartTime = tick()

                            while AutoGEnabled and (tick() - StartTime) < 2 do
                                PressG()
                                task.wait(0.25)
                            end
                        end
                    end

                    task.wait(0.25)
                end

                AutoGThread = nil
            end)
        else
            AutoGEnabled = false
        end
    end
})

